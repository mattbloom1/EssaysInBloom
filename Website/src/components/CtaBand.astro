---
interface Props {
  title?: string;
  buttonLabel?: string;
  buttonHref?: string;
}
const {
  title = 'Ready to grow your story?',
  buttonLabel = 'Book a free consult',
  buttonHref = '/contact/',
} = Astro.props;
---

<section class="section" data-reveal>
  <div class="container">
    <div class="cta" data-reveal-child>
      <h2 class="cta__title">{title}</h2>
      <a href={buttonHref} class="btn btn--cream">{buttonLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--gradient-bloom);
    border-radius: var(--radius-lg);
    padding: var(--space-16) var(--space-12);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .cta__title {
    color: var(--soft-linen);
    max-width: 18ch;
  }

  @media (max-width: 640px) {
    .cta {
      padding: var(--space-10) var(--space-8);
    }
  }
</style>
