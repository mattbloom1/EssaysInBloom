---
import { withBase } from '../lib/withBase';

interface Props {
  title?: string;
  buttonLabel?: string;
  buttonHref?: string;
}
const {
  title = 'Ready to grow your story?',
  buttonLabel = 'Book a free consult',
  buttonHref = withBase('/contact/'),
} = Astro.props;
---

<!-- Full-bleed band; the inner panel starts container-width and motion.ts
     scrubs it out to 100vw as it scrolls into view. The canvas is the
     animated liquid mesh gradient (mesh-gradient.ts); the CSS gradient
     underneath is the no-WebGL / reduced-motion fallback. -->
<section class="cta-band" data-cta-band>
  <div class="cta" data-cta>
    <canvas class="cta__mesh" data-cta-mesh aria-hidden="true"></canvas>
    <div class="cta__scrim" aria-hidden="true"></div>
    <div class="cta__content" data-reveal>
      <h2 class="cta__title" data-reveal-child>{title}</h2>
      <a href={buttonHref} class="btn btn--cream" data-reveal-child>{buttonLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    /* no bottom padding: the band always sits last in <main>, and the
       expanded panel should meet the footer edge-to-edge */
    padding-block: var(--space-20) 0;
  }

  .cta {
    position: relative;
    overflow: hidden;
    width: min(100% - 3rem, var(--container-max));
    margin-inline: auto;
    border-radius: var(--radius-lg);
    background: var(--gradient-bloom);
  }

  .cta__mesh {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Keeps the title's side of the panel dark enough for the cream text no
     matter where the mesh's bronze highlights drift. */
  .cta__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      color-mix(in srgb, var(--evergreen) 55%, transparent) 0%,
      color-mix(in srgb, var(--evergreen) 20%, transparent) 55%,
      transparent 80%
    );
  }

  .cta__content {
    position: relative;
    padding: var(--space-16) var(--space-12);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    /* content stays container-width even once the panel is full-bleed */
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .cta__title {
    color: var(--soft-linen);
    max-width: 18ch;
  }

  @media (max-width: 640px) {
    .cta__content {
      padding: var(--space-10) var(--space-8);
    }
  }
</style>
