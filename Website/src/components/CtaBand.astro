---
import { withBase } from '../lib/withBase';

interface Props {
  title?: string;
  buttonLabel?: string;
  buttonHref?: string;
}
const {
  title = 'Ready to grow your story?',
  buttonLabel = 'Book a free consult',
  buttonHref = withBase('/contact/'),
} = Astro.props;
---

<!-- Full-bleed band; the inner panel starts container-width and motion.ts
     scrubs it out to full width as it scrolls into view. The canvas is the
     animated liquid mesh gradient (mesh-gradient.ts), held at viewport width
     so the widening panel reveals more of it instead of stretching it; the
     CSS gradient underneath is the no-WebGL / reduced-motion fallback. -->
<section class="cta-band" data-cta-band>
  <div class="cta" data-cta>
    <canvas class="cta__mesh" data-cta-mesh aria-hidden="true"></canvas>
    <div class="cta__scrim" aria-hidden="true"></div>
    <!-- No reveal animation here: the band sits at the very bottom of every
         page, so a scroll-triggered pop-in fires right as the user lands on
         it — the width scrub is the band's only motion. -->
    <div class="cta__content">
      <h2 class="cta__title">{title}</h2>
      <a href={buttonHref} class="btn btn--cream">{buttonLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    /* symmetric padding: the band sits last in <main>, with breathing room
       between the expanded panel and the footer */
    padding-block: var(--space-20);
  }

  .cta {
    position: relative;
    overflow: hidden;
    width: min(100% - 3rem, var(--container-max));
    margin-inline: auto;
    border-radius: var(--radius-lg);
    background: var(--gradient-bloom);
  }

  /* Pinned at viewport width and centered, so its size never changes while
     the panel's width animates — the panel just clips a stable gradient
     (stretching the canvas would warp the noise field every scroll frame).
     Explicit height is load-bearing: a replaced element ignores top/bottom
     stretching and falls back to its intrinsic (buffer) height, which the
     mesh script derives from clientHeight — a runaway feedback loop. */
  .cta__mesh {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    display: block;
  }

  /* Keeps the title's side of the panel dark enough for the cream text no
     matter where the mesh's bronze highlights drift. Pinned at viewport
     width exactly like the canvas: sized to the panel (inset: 0) its sweep
     would visibly stretch while the panel's width animates. */
  .cta__scrim {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    background: linear-gradient(
      100deg,
      color-mix(in srgb, var(--evergreen) 55%, transparent) 0%,
      color-mix(in srgb, var(--evergreen) 20%, transparent) 55%,
      transparent 80%
    );
  }

  .cta__content {
    position: relative;
    padding: var(--space-12) var(--space-10);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    /* content stays container-width even once the panel is full-bleed */
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .cta__title {
    color: var(--soft-linen);
    max-width: 18ch;
  }

  @media (max-width: 640px) {
    .cta-band {
      padding-block: var(--space-16);
    }

    .cta__content {
      padding: var(--space-10) var(--space-6);
    }
  }
</style>
