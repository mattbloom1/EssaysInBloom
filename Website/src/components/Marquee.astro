---
import type { School } from '../data/schools';

interface Props {
  logos: School[];
}
const { logos } = Astro.props;
---

<div class="marquee" role="presentation">
  <div class="marquee__track">
    {logos.map((school) => (
      <span class="marquee__logo">
        <img src={school.logo} alt={school.alt} width={school.width} height={school.height} loading="eager" />
      </span>
    ))}
    {/* duplicate once so the -50% keyframe loops seamlessly */}
    {logos.map((school) => (
      <span class="marquee__logo" aria-hidden="true">
        <img src={school.logo} alt="" width={school.width} height={school.height} loading="lazy" />
      </span>
    ))}
  </div>
</div>
