---
import { withBase } from '../lib/withBase';
import BloomMark from './BloomMark.astro';

const nav = [
  { href: withBase('/about/'), label: 'About' },
  { href: withBase('/approach/'), label: 'Approach' },
  { href: withBase('/coaching/'), label: 'Coaching' },
  { href: withBase('/workshops/'), label: 'Workshops' },
  { href: withBase('/testimonials/'), label: 'Testimonials' },
];

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path === href.replace(/\/$/, '');
---

<header class="header">
  <div class="container header__bar">
    <a href={withBase('/')} class="header__logo" aria-label="Essays in Bloom — home">
      <BloomMark />
    </a>
    <nav class="header__nav" aria-label="Main" id="site-nav">
      {nav.map(({ href, label }) => (
        <a href={href} class="link" aria-current={isActive(href) ? 'page' : undefined}>
          {label}
        </a>
      ))}
      {/* Only rendered visible inside the mobile overlay — on desktop the
          standalone pill below is the contact CTA. */}
      <a href={withBase('/contact/')} class="btn btn--cream header__nav-cta">Contact</a>
    </nav>
    <a href={withBase('/contact/')} class="btn btn--primary header__cta">Contact</a>
    {/* TODO(matt): swap the hamburger lines for the brand moment — a closed
        book that opens when the menu is open (see TODO.md, "Mobile nav book
        icon"). The button styling below is ready for an SVG swap. */}
    <button
      class="header__menu"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Open menu"
      data-menu-toggle
    >
      <span class="header__menu-line" aria-hidden="true"></span>
      <span class="header__menu-line" aria-hidden="true"></span>
    </button>
  </div>
</header>

<script>
  /* ClientRouter swaps the header DOM on every navigation, so element
     listeners are bound per page inside astro:page-load; the Escape handler
     is document-level and bound once, resolving the header lazily. */
  const setOpen = (open: boolean) => {
    const header = document.querySelector('.header');
    const toggle = header?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    if (!header || !toggle) return;
    header.classList.toggle('is-open', open);
    // scroll lock while the full-screen overlay is up
    document.documentElement.classList.toggle('menu-open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };

  document.addEventListener('astro:page-load', () => {
    const header = document.querySelector('.header')!;
    const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]')!;

    toggle.addEventListener('click', () => {
      setOpen(!header.classList.contains('is-open'));
    });

    // Close when a nav link is chosen.
    header.querySelectorAll('.header__nav a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  // Rotating / resizing past the breakpoint hides the toggle while the
  // overlay's scroll lock persists — release it.
  window.matchMedia('(min-width: 821px)').addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10;
  }

  /* The translucent blur lives on a pseudo-layer, NOT on .header itself:
     a backdrop-filter on the header would make it the containing block for
     position: fixed descendants, shrinking the full-screen mobile menu
     overlay down to the bar. */
  .header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--color-paper) 88%, transparent);
    -webkit-backdrop-filter: blur(12px); /* iOS Safari < 18 */
    backdrop-filter: blur(12px);
  }

  .header__bar {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-4);
  }

  .header__logo {
    display: inline-flex;
    color: var(--color-ink);
  }

  .header__logo :global(svg) {
    height: 44px;
    width: auto;
  }

  .header__nav {
    display: flex;
    gap: var(--space-6);
    margin-inline-start: auto;
    font-family: var(--font-subheading);
    font-weight: var(--weight-subheading);
    text-transform: uppercase;
    font-size: var(--text-sm);
    color: var(--color-primary);
  }

  .header__menu {
    display: none;
  }

  /* The contact link inside the nav only exists for the mobile overlay;
     desktop keeps the standalone pill. */
  .header__nav-cta {
    display: none;
  }

  /* Page scroll is locked while the overlay menu is up (class toggled in
     the script above). */
  :global(html.menu-open) {
    overflow: hidden;
  }

  @media (max-width: 820px) {
    .header__cta {
      display: none;
    }

    /* Logo and toggle sit above the fixed overlay so the bar stays usable
       while the menu is open. */
    .header__logo,
    .header__menu {
      position: relative;
      z-index: 1;
    }

    /* Menu button: two lines that form an X when open (placeholder for the
       closed/open book icon). ≥44px touch target. */
    .header__menu {
      display: grid;
      gap: 7px;
      align-content: center;
      justify-items: center;
      min-width: 44px;
      min-height: 44px;
      margin-inline-start: auto;
      background: none;
      border: 0;
      padding: var(--space-2);
      cursor: pointer;
    }

    .header__menu-line {
      width: 26px;
      height: 3px;
      border-radius: 2px;
      background: var(--color-primary);
      transition:
        transform var(--dur-fast) var(--ease-out-soft),
        background var(--dur-fast) var(--ease-out-soft);
    }

    .is-open .header__menu-line:first-child {
      transform: translateY(5px) rotate(45deg);
    }

    .is-open .header__menu-line:last-child {
      transform: translateY(-5px) rotate(-45deg);
    }

    /* Open menu covers the page in evergreen — logo, X, and links go cream */
    .is-open .header__logo {
      color: var(--soft-linen);
    }

    .is-open .header__menu-line {
      background: var(--soft-linen);
    }

    /* The nav becomes a full-screen brand-colored overlay. */
    .header__nav {
      position: fixed;
      inset: 0;
      display: grid;
      align-content: center;
      justify-items: center;
      gap: var(--space-2);
      /* keep clear of the bar (logo + X) at the top */
      padding: calc(76px + var(--space-8)) var(--space-6) var(--space-10);
      overscroll-behavior: contain;
      background: var(--color-primary);
      color: var(--soft-linen);
      text-align: center;
      font-size: var(--text-2xl);

      visibility: hidden;
      opacity: 0;
      translate: 0 -12px;
      transition:
        opacity var(--dur-fast) var(--ease-out-soft),
        translate var(--dur-fast) var(--ease-out-soft),
        visibility 0s var(--dur-fast);
    }

    .is-open .header__nav {
      visibility: visible;
      opacity: 1;
      translate: 0 0;
      transition:
        opacity var(--dur-fast) var(--ease-out-soft),
        translate var(--dur-fast) var(--ease-out-soft);
    }

    .header__nav a {
      padding-block: var(--space-3);
    }

    /* accent-green focus rings vanish on evergreen */
    .header__nav :global(:focus-visible) {
      outline-color: var(--soft-linen);
    }

    .header__nav-cta {
      display: inline-flex;
      margin-top: var(--space-6);
      padding-inline: var(--space-10);
      font-size: var(--text-base);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header__menu-line,
    .header__nav {
      transition: none;
    }
  }
</style>
