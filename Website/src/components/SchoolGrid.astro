---
import type { School } from '../data/schools';

interface Props {
  schools: School[];
}
const { schools } = Astro.props;
---

<ul class="school-grid">
  {schools.map((school) => (
    <li class="school-grid__item" data-reveal-child>
      <a class="school-grid__link" href={school.url} target="_blank" rel="noopener noreferrer">
        <img src={school.logo} alt={school.alt} width={school.width} height={school.height} loading="lazy" />
        <span class="school-grid__name">{school.name}</span>
      </a>
    </li>
  ))}
</ul>
