---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import CtaBand from '../components/CtaBand.astro';
import { testimonials } from '../data/testimonials';
---

<Base title="Testimonials — Essays in Bloom" description="Real words from the students and parents Alison has worked with.">
  <main>
    <PageIntro
      eyebrow="Testimonials"
      title="Stories that bloomed"
      lede="Real words from the students and parents Alison has worked with."
    />
    <section class="section container container--narrow" data-reveal>
      <div class="testimonial-page-list">
        {testimonials.map((t) => (
          <figure class="testimonial" data-reveal-child>
            <blockquote>
              <p>“{t.quote}”</p>
            </blockquote>
            <figcaption>{t.attribution}</figcaption>
          </figure>
        ))}
      </div>
    </section>
    <CtaBand />
  </main>
</Base>

<style>
  /* Entry styling is the shared .testimonial class in components.css */
  .testimonial-page-list {
    display: grid;
  }
</style>
