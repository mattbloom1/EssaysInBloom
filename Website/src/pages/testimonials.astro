---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import CtaBand from '../components/CtaBand.astro';
import { testimonials } from '../data/testimonials';
---

<Base title="Testimonials — Essays in Bloom" description="Real words from the students and parents Alison has worked with.">
  <main>
    <PageIntro
      eyebrow="Testimonials"
      title="Stories that bloomed"
      lede="Real words from the students and parents Alison has worked with."
    />
    <section class="section container container--narrow" data-reveal>
      <div class="testimonial-page-list">
        {testimonials.map((t) => (
          <figure class="testimonial-full" data-reveal-child>
            <blockquote>
              <p>“{t.quote}”</p>
            </blockquote>
            <figcaption>{t.attribution}</figcaption>
          </figure>
        ))}
      </div>
    </section>
    <CtaBand />
  </main>
</Base>

<style>
  .testimonial-page-list {
    display: grid;
  }

  .testimonial-full {
    margin: 0;
    padding-block: var(--space-10);
    display: grid;
    gap: var(--space-5);
  }

  /* soft divider bar, not a hard border */
  .testimonial-full + .testimonial-full::before {
    content: '';
    width: 48px;
    height: 3px;
    border-radius: 2px;
    background: var(--soft-50);
    margin-bottom: var(--space-6);
  }

  .testimonial-full blockquote {
    margin: 0;
  }

  .testimonial-full blockquote p {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-primary);
    text-wrap: pretty;
  }

  .testimonial-full figcaption {
    font-family: var(--font-subheading);
    font-weight: var(--weight-subheading);
    text-transform: uppercase;
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
</style>
