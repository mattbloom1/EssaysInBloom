---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import CtaBand from '../components/CtaBand.astro';

/* NOTE: all copy below is placeholder — rewrite freely. */

const marqueeItems = [
  'Common App essays',
  'Supplemental essays',
  'Personal statements',
  'Brainstorming',
  'Activity lists',
  'Scholarship essays',
  'Interview prep',
];

const steps = [
  {
    n: '01',
    title: 'Discover',
    body: 'We clarify the roles you play, what you do, and what you care about — the raw material of your story.',
  },
  {
    n: '02',
    title: 'Draft',
    body: 'An iterative drafting process turns discovery into essays with a real voice — yours.',
  },
  {
    n: '03',
    title: 'Refine',
    body: 'We shape every Common App and supplemental essay into one vibrant, cohesive narrative.',
  },
  {
    n: '04',
    title: 'Bloom',
    body: 'You submit with confidence, showing admissions officers exactly why you belong.',
  },
];
---

<Base>
  <main>
    <!-- Hero -->
    <section class="section hero" data-hero>
      <div class="container hero__grid">
        <div class="hero__copy">
          <p class="eyebrow" data-hero-copy>College application essay coaching</p>
          <h1 data-hero-title>What’s <span class="tint">your</span> story?</h1>
          <p class="lede" data-hero-copy>
            Not sure? Together, we clarify the roles you play, what you do, and
            what you care about — and grow it into a narrative that shows
            admissions officers exactly why you belong.
          </p>
          <div class="hero__actions" data-hero-actions>
            <a href="/contact/" class="btn btn--primary">Book a free consult</a>
            <a href="/approach/" class="btn btn--soft">How it works</a>
          </div>
        </div>
        <div class="hero__mark" aria-hidden="true">
          <img src="/logos/mark.svg" alt="" width="440" height="242" loading="eager" />
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <div class="strip">
      <Marquee items={marqueeItems} />
    </div>

    <!-- Services bento -->
    <section class="section" data-reveal>
      <div class="container">
        <div class="section__head">
          <p class="eyebrow" data-reveal-child>What we do</p>
          <h2 data-reveal-child>Every essay starts with a story</h2>
        </div>
        <div class="bento">
          <article class="card card--primary card--hover span-3" data-reveal-child>
            <h3>1:1 Essay Coaching</h3>
            <p>
              Personal, iterative coaching from brainstorm to final draft —
              Common App, supplementals, and everything in between.
            </p>
          </article>
          <article class="card card--soft card--hover span-3" data-reveal-child>
            <h3>Workshops</h3>
            <p>
              Small-group sessions that take the fear out of the blank page and
              get real drafts moving.
            </p>
          </article>
          <article class="card card--photo span-2" data-reveal-child>
            <img
              src="/pictures/writing-closeup.jpg"
              alt="A student writing by hand"
              width="800"
              height="600"
              loading="lazy"
            />
          </article>
          <article class="card card--peri card--hover span-2" data-reveal-child>
            <h3>Application Strategy</h3>
            <p>
              Activity lists, interviews, and the story that ties your whole
              application together.
            </p>
          </article>
          <article class="card card--paper span-2" data-reveal-child>
            <p class="bento__quote">
              “Your Common App and supplemental essays bloom into a vibrant,
              cohesive narrative.”
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="section process" data-reveal>
      <div class="container">
        <div class="section__head">
          <p class="eyebrow" data-reveal-child>The approach</p>
          <h2 data-reveal-child>From seed to story</h2>
        </div>
        <div class="bento">
          {steps.map((step) => (
            <article class="card card--paper span-3 step" data-reveal-child>
              <span class="step__n">{step.n}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section" data-reveal>
      <div class="container">
        <div class="section__head">
          <p class="eyebrow" data-reveal-child>Kind words</p>
          <h2 data-reveal-child>Stories that bloomed</h2>
        </div>
        <div class="bento">
          <!-- TODO: real testimonials -->
          <figure class="card card--soft span-3 quote" data-reveal-child>
            <blockquote>
              “Placeholder testimonial — a few sentences from a student or
              parent about working together.”
            </blockquote>
            <figcaption>Student, Class of 2026</figcaption>
          </figure>
          <figure class="card card--peri-tint span-3 quote" data-reveal-child>
            <blockquote>
              “Placeholder testimonial — another voice, ideally a contrasting
              perspective (parent, different school year).”
            </blockquote>
            <figcaption>Parent</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <CtaBand />
  </main>
</Base>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-16);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    align-items: center;
    gap: var(--space-12);
  }

  .hero__copy {
    display: grid;
    gap: var(--space-6);
    justify-items: start;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .hero__mark img {
    width: 100%;
    height: auto;
    opacity: 0.9;
  }

  .strip {
    padding-block: var(--space-6);
    background: var(--soft-10);
  }

  .bento__quote {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    line-height: 1.3;
    color: var(--color-primary);
  }

  .step {
    display: grid;
    gap: var(--space-2);
    align-content: start;
  }

  .step__n {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--periwinkle);
  }

  .quote blockquote {
    margin: 0 0 var(--space-4);
    font-size: var(--text-md);
    line-height: 1.5;
  }

  .quote figcaption {
    font-family: var(--font-subheading);
    font-weight: var(--weight-subheading);
    text-transform: uppercase;
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__mark {
      display: none;
    }
  }
</style>
