---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/withBase';
import SchoolGrid from '../components/SchoolGrid.astro';
import CtaBand from '../components/CtaBand.astro';
import { schools } from '../data/schools';
import { testimonials } from '../data/testimonials';

/* NOTE: all copy below is placeholder — rewrite freely. */

const homepageTestimonials = testimonials.filter((t) => t.featured);

/* From seed to story — each step pairs a coaching phase with a growth stage.
   The `art` SVGs are PLACEHOLDERS (simple line drawings, currentColor):
   swap each for final artwork or a Lottie animation when Matt makes them. */
const steps = [
  {
    n: '01',
    stage: 'Seed',
    title: 'Discover',
    body: 'We clarify the roles you play, what you do, and what you care about — the raw material of your story.',
    art: `<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 74h88"/><path d="M63 106c-8-3-12-11-10-20 9 2 14 10 13 18-1 1-2 2-3 2Z"/><path d="M44 64l-4-8"/><path d="M76 64l4-8"/><path d="M60 60v-9"/></svg>`,
  },
  {
    n: '02',
    stage: 'Plant',
    title: 'Draft',
    body: 'An iterative drafting process turns discovery into essays with a real voice — yours.',
    art: `<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 88h88"/><path d="M60 88V56"/><path d="M60 68C49 67 42 59 41 48c11 1 18 9 19 20Z"/><path d="M60 58c11-1 18-9 19-20-11 1-18 9-19 20Z"/></svg>`,
  },
  {
    n: '03',
    stage: 'Water',
    title: 'Refine',
    body: 'We shape every Common App and supplemental essay into one vibrant, cohesive narrative.',
    art: `<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 96h88"/><path d="M44 96V76"/><path d="M44 84c-9-1-15-7-16-16 9 1 15 7 16 16Z"/><rect x="70" y="24" width="26" height="18" rx="5" transform="rotate(16 83 33)"/><path d="M72 34l-12 7"/><path d="M92 20c7-5 13 0 11 7"/><path d="M56 52l-2 5"/><path d="M50 61l-2 5"/><path d="M60 62l-2 5"/></svg>`,
  },
  {
    n: '04',
    stage: 'Bloom',
    title: 'Bloom',
    body: 'You submit with confidence, showing admissions officers exactly why you belong.',
    art: `<svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 102h88"/><path d="M60 102V58"/><path d="M60 86c-11-1-18-9-19-20 11 1 18 9 19 20Z"/><path d="M60 78c11-1 18-9 19-20-11 1-18 9-19 20Z"/><circle cx="60" cy="36" r="7"/><ellipse cx="60" cy="19" rx="6.5" ry="10"/><ellipse cx="60" cy="19" rx="6.5" ry="10" transform="rotate(60 60 36)"/><ellipse cx="60" cy="19" rx="6.5" ry="10" transform="rotate(120 60 36)"/><ellipse cx="60" cy="19" rx="6.5" ry="10" transform="rotate(180 60 36)"/><ellipse cx="60" cy="19" rx="6.5" ry="10" transform="rotate(240 60 36)"/><ellipse cx="60" cy="19" rx="6.5" ry="10" transform="rotate(300 60 36)"/></svg>`,
  },
];
---

<Base>
  <main id="main">
    <!-- Hero -->
    <section class="section hero" data-hero>
      <div class="hero__frame">
        <div class="hero__media" data-hero-media>
          <img
            src={withBase('/pictures/hero-writing.jpg')}
            alt="A student writing an essay by hand in a sunlit classroom"
            width="1300"
            height="1625"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="hero__copy">
          <p class="eyebrow" data-hero-copy>College application essay coaching</p>
          <h1 data-hero-title>What’s <span class="tint">your</span> <span data-story-flip>story</span>?</h1>
          <p class="lede" data-hero-copy>
            Not sure? Together, we clarify the roles you play, what you do, and
            what you care about — and grow it into a narrative that shows
            admissions officers exactly why you belong.
          </p>
          <div class="hero__actions" data-hero-actions>
            <a href={withBase('/contact/')} class="btn btn--primary">Book a free consult</a>
            <a href={withBase('/approach/')} class="btn btn--cream">How it works</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Services bento -->
    <section class="section" data-reveal>
      <div class="container">
        <div class="section__head">
          <p class="eyebrow" data-reveal-child>What we do</p>
          <h2 data-reveal-child>Every essay starts with a story</h2>
        </div>
        <div class="bento">
          <article class="card card--primary card--hover span-3" data-reveal-child>
            <h3>1:1 Essay Coaching</h3>
            <p>
              Personal, iterative coaching from brainstorm to final draft —
              Common App, supplementals, and everything in between.
            </p>
          </article>
          <article class="card card--soft card--hover span-3" data-reveal-child>
            <h3>Workshops</h3>
            <p>
              Small-group sessions that take the fear out of the blank page and
              get real drafts moving.
            </p>
          </article>
          <article class="card card--photo span-2" data-reveal-child>
            <img
              src={withBase('/pictures/writing-closeup.jpg')}
              alt="A student writing by hand"
              width="1200"
              height="801"
              loading="lazy"
            />
          </article>
          <article class="card card--peri card--hover span-2" data-reveal-child>
            <h3>Application Strategy</h3>
            <p>
              Activity lists, interviews, and the story that ties your whole
              application together.
            </p>
          </article>
          <article class="card card--paper span-2" data-reveal-child>
            <p class="bento__quote">
              “Your Common App and supplemental essays bloom into a vibrant,
              cohesive narrative.”
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Colleges -->
    <section class="section school-section" data-reveal>
      <div class="container">
        <div class="section__head section__head--center">
          <h2 data-reveal-child>Colleges our students now call home</h2>
        </div>
        <SchoolGrid schools={schools} />
        <p class="school-grid__caption">Logos are trademarks of their respective institutions.</p>
      </div>
    </section>

    <!-- Process: pinned horizontal seed-to-story timeline -->
    <section class="section process" data-process>
      <div class="container">
        <div class="section__head section__head--center">
          <p class="eyebrow">The approach</p>
          <h2>From seed to story</h2>
        </div>
      </div>
      <div class="process__stage" data-process-stage>
        <div class="process__track" data-process-track>
          {steps.map((step) => (
            <article class="process__step" data-process-step>
              <div class="process__art" set:html={step.art} />
              <span class="process__node" aria-hidden="true"></span>
              <p class="process__stagename">{step.n} · {step.stage}</p>
              <h3>{step.title}</h3>
              <p class="process__body">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section" data-reveal>
      <div class="container">
        <div class="section__head section__head--center">
          <p class="eyebrow" data-reveal-child>Kind words</p>
          <h2 data-reveal-child>Stories that bloomed</h2>
        </div>
        <div class="testimonial-list">
          {homepageTestimonials.map((t) => (
            <figure class="testimonial testimonial--center" data-reveal-child>
              <blockquote>
                <p>“{t.excerpt ?? t.quote}”</p>
              </blockquote>
              <figcaption>{t.attribution}</figcaption>
            </figure>
          ))}
        </div>
        <p class="testimonials__more" data-reveal-child>
          <a href={withBase('/testimonials/')} class="btn btn--soft">Read more stories</a>
        </p>
      </div>
    </section>

    <CtaBand />
  </main>
</Base>

<style>
  .hero {
    padding-block: var(--space-8) var(--space-16);
  }

  /* The rounded photo frame is the hero: 90% of the viewport, copy centered
     on top. The media (and its scrim) sit absolutely behind the copy. */
  .hero__frame {
    position: relative;
    width: 90%;
    margin-inline: auto;
    min-height: clamp(480px, 72vh, 680px);
    display: grid;
    place-items: center;
  }

  .hero__copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-6);
    justify-items: center;
    text-align: center;
    padding: var(--space-12) var(--space-6);
    max-width: 46rem;
    color: var(--soft-linen);
  }

  .hero__copy h1 {
    color: var(--soft-linen);
  }

  /* Over the dark scrim: the small eyebrow needs full AA contrast, so it
     goes cream; bronze stays only on the large "your" (3:1 large-text bar). */
  .hero__copy .eyebrow {
    color: var(--soft-linen);
  }

  .hero__copy .tint {
    color: var(--color-soft);
  }

  /* accent-green focus rings vanish on the scrim */
  .hero__copy :global(:focus-visible) {
    outline-color: var(--soft-linen);
  }

  /* Hover easter egg (motion.ts): while the pointer rests on the title, the
     word "story" cycles through the brand's type families via data-font. */
  [data-story-flip] {
    /* inline-block so the word swaps as one unit instead of re-wrapping */
    display: inline-block;
  }

  [data-story-flip][data-font='1'] {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
  }

  [data-story-flip][data-font='2'] {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    /* the hand script reads as scribble in caps — show it lowercase */
    text-transform: lowercase;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  /* Hero photo: rounded clipping box filling the frame; the oversized img
     inside is what the parallax tween in motion.ts moves, so travel stays
     within these bounds. */
  .hero__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }

  .hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 126%; /* extra height = parallax travel room */
    object-fit: cover;
    will-change: transform;
  }

  /* Scrim so the centered copy stays readable over the sunlit photo */
  .hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(19 52 48 / 0.55), rgb(43 38 34 / 0.6));
  }

  .school-section {
    background: var(--soft-10);
  }

  .school-grid__caption {
    margin-top: var(--space-8);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-ink);
    opacity: 0.6;
  }

  .bento__quote {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    line-height: 1.3;
    color: var(--color-primary);
  }

  /* --- Seed-to-story timeline --- */
  .process {
    /* the pin needs breathing room, not double padding */
    padding-block: var(--space-20) 0;
  }

  .process__stage {
    /* JS pins this and drives the track's x. Without JS (or with reduced
       motion) it degrades to a native horizontal scroller with snap. */
    height: max(440px, calc(100svh - 320px));
    display: grid;
    align-items: center;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    padding-bottom: var(--space-8);
  }

  .process__stage.is-pinned {
    overflow: hidden;
  }

  .process__track {
    --step-w: min(440px, 78vw);
    position: relative;
    display: flex;
    gap: clamp(4rem, 10vw, 8rem);
    width: max-content;
    padding-inline: calc(50vw - var(--step-w) / 2);
    align-items: stretch;
  }

  /* The timeline rule: runs behind every node dot (fixed art height keeps
     the nodes on one line across steps). */
  .process__track::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: calc(120px + var(--space-6) + 5px);
    height: 2px;
    border-radius: 1px;
    background: var(--soft-50);
  }

  .process__step {
    width: var(--step-w);
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-3);
    scroll-snap-align: center;
  }

  .process__art {
    height: 120px;
    width: 120px;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .process__art :global(svg) {
    width: 100%;
    height: 100%;
  }

  .process__node {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-top: -13px; /* sit on the timeline rule */
    margin-bottom: var(--space-4);
  }

  .process__stagename {
    font-family: var(--font-subheading);
    font-weight: var(--weight-subheading);
    text-transform: uppercase;
    font-size: var(--text-sm);
    /* was --periwinkle: 2.6:1 on paper, fails AA — periwinkle is
       dark-text-only per DESIGN.md */
    color: var(--color-accent);
  }

  .process__step h3 {
    font-size: var(--text-xl);
    color: var(--color-primary);
  }

  .process__body {
    max-width: 38ch;
  }

  /* --- Testimonials (shared .testimonial styles live in components.css) --- */
  .testimonial-list {
    display: grid;
    /* stacked reading column while the entries flow vertically */
    max-width: var(--container-narrow);
    margin-inline: auto;
  }

  /* Desktop: the three featured quotes sit side by side */
  @media (min-width: 901px) {
    .testimonial-list {
      max-width: none;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-10);
      align-items: start;
    }

    /* the divider bars and tall stacked padding only make sense vertically */
    .testimonial-list .testimonial + .testimonial::before {
      display: none;
    }

    .testimonial-list .testimonial {
      padding-block: var(--space-6) 0;
    }

    /* the homepage pull-quote size is tuned for one wide column; step it
       down so three abreast don't fight each other */
    .testimonial-list .testimonial blockquote p {
      font-size: var(--text-lg);
    }
  }

  .testimonials__more {
    margin-top: var(--space-4);
    text-align: center;
  }

  @media (max-width: 900px) {
    .hero {
      padding-block: var(--space-6) var(--space-12);
    }

    .hero__frame {
      min-height: min(78vh, 560px);
    }

    .hero__copy {
      padding: var(--space-10) var(--space-4);
    }
  }
</style>
