---
import Base from '../layouts/Base.astro';
---

<Base>
  <main>
    <h1>Essays in Bloom</h1>
    <p>New site under construction.</p>
  </main>
</Base>

<style>
  main {
    display: grid;
    place-content: center;
    min-height: 100dvh;
    text-align: center;
  }

  h1 {
    font-family: var(--font-heading);
    font-weight: 400;
    color: var(--color-primary);
    font-size: 3rem;
    margin: 0;
  }

  p {
    color: var(--color-ink);
  }
</style>
