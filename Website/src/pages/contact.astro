---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';

/* Calendly: replace with the real scheduling link (e.g.
   https://calendly.com/essaysinbloom/free-consult) and the embed goes live —
   everything below keys off this one constant. While it still contains
   REPLACE-ME the page shows the email card as the primary action instead of
   a broken Calendly frame. */
const CALENDLY_URL = 'https://calendly.com/REPLACE-ME/free-consult';
const calendlyReady = !CALENDLY_URL.includes('REPLACE-ME');
---

<Base title="Contact — Essays in Bloom" description="Book a free consult — tell us where you are in the application process.">
  <main id="main">
    <PageIntro
      eyebrow="Contact"
      title="Let's talk"
      lede="Tell us a little about where you are in the application process, and we'll set up a free consult."
    />

    {calendlyReady && (
      <section class="section section--flush container" data-reveal>
        <div class="card card--paper booking" data-reveal-child>
          <h2 class="booking__title">Book your free consult</h2>
          <div
            class="calendly-inline-widget"
            data-url={`${CALENDLY_URL}?hide_gdpr_banner=1&primary_color=29603d`}
            style="min-width:320px;height:720px;"
          >
          </div>
        </div>
        <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
      </section>
    )}

    <section class="section container container--narrow" data-reveal>
      <div class="contact-grid">
        <div class="card card--soft contact-card" data-reveal-child>
          {calendlyReady ? (
            <h3>Prefer email?</h3>
          ) : (
            <h3>For now, email works best</h3>
          )}
          <p>We read everything and reply personally.</p>
          <a href="mailto:essaysinbloom@gmail.com" class="btn btn--primary">
            essaysinbloom@gmail.com
          </a>
        </div>
        <div class="card card--paper contact-card" data-reveal-child>
          <h3>Helpful to include</h3>
          <ul class="check-list">
            <li>Student's grade year and application deadlines</li>
            <li>Where you are — no topic yet, drafting, or polishing</li>
            <li>Whether you're thinking 1:1 coaching or a workshop</li>
          </ul>
          <p class="contact-note">Replies typically within a couple of days.</p>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .section--flush {
    padding-block-end: 0;
  }

  .booking {
    display: grid;
    gap: var(--space-6);
  }

  .booking__title {
    font-size: var(--text-2xl);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .contact-card {
    display: grid;
    gap: var(--space-4);
    justify-items: start;
    align-content: start;
  }

  .contact-note {
    font-size: var(--text-sm);
    opacity: 0.7;
  }

  /* The email-address label can't wrap cleanly — let it shrink a touch on
     the narrowest phones instead of breaking mid-address */
  @media (max-width: 360px) {
    .contact-card .btn {
      font-size: var(--text-xs);
      padding-inline: 1em;
    }
  }

  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
